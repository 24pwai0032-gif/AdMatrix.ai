# Database
DATABASE_URL=postgresql+asyncpg://admatrix:admatrix@localhost:5432/admatrix

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# AI providers
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
WAN27_API_URL=https://api.wan27.ai/v1/image-to-video
HAPPYHORSE_API_URL=https://api.happyhorse.ai/v1/i2v

# Security (set API_KEY in production to require X-API-Key header)
API_KEY=
VIDEO_SIGNING_SECRET=
VIDEO_URL_TTL_SECONDS=3600
ENVIRONMENT=development
USE_GUNICORN=false
WEB_CONCURRENCY=2
CELERY_TASK_TIME_LIMIT=600
MAX_REVISIONS=5

# Application
DEMO_MODE=false
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
BUDGET_THRESHOLD_USD=10.0
MAX_SCRAPE_BYTES=5000000
VIDEO_OUTPUT_DIR=/tmp/admatrix/videos

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_DEMO_MODE=false
NEXT_PUBLIC_API_KEY=

# Alibaba Cloud deploy (deploy.sh)
ACR_REGISTRY=registry.cn-hangzhou.aliyuncs.com
ACR_NAMESPACE=admatrix
ACR_USERNAME=
ACR_PASSWORD=
ECS_HOST=
